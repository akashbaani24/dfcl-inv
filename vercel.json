{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "PRISMA_DATABASE_URL=file:db.sqlite prisma generate && next build",
  "installCommand": "bun install",
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 30
    }
  },
  "github": {
    "silent": true
  }
}
