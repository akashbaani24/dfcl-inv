# Environment variables for DFCL Inventory App
# Copy this file to .env and adjust for your environment.

# === LOCAL DEVELOPMENT (default) ===
# Local SQLite database (file-based, no server needed)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# === VERCEL + TURSO PRODUCTION ===
# Set these on Vercel (and in GitHub Secrets for Actions) to use Turso:
# TURSO_DATABASE_URL=libsql://your-db-handle.turso.io
# TURSO_AUTH_TOKEN=eyJhbGciOi...
# (DATABASE_URL should also be set to the Turso URL for Prisma)

# === CLOUDFLARE PAGES + D1 (optional alternative) ===
# D1 binding is injected automatically; this var is just a signal to Prisma
# D1_DATABASE_ID=f85696ac-e6ac-43ca-96cb-6cda76cf7fc5
