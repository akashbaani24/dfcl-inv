generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Use PRISMA_DATABASE_URL (with file: fallback) instead of DATABASE_URL directly,
  // so that Vercel's DATABASE_URL (which might be postgres:// from another service)
  // doesn't break Prisma's runtime validation when using driver adapters.
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String
  displayName   String
  role          String   @default("user") // "admin", "manager", or "user"
  canCreateItem Boolean  @default(false)
  canModifyItem Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  columnAccess      UserColumnAccess[]
  entityAccess      UserEntityAccess[]
  menuAccess        UserMenuAccess[]
  masterDataAccess  UserMasterDataAccess[]
  sessions          Session[]
}

model UserColumnAccess {
  id         String @id @default(cuid())
  userId     String
  columnName String  // "year", "lcNo", "group", "subGroup", "itemName", "price", "uom", "stockQty"
  canView    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, columnName])
}

model UserEntityAccess {
  id       String @id @default(cuid())
  userId   String
  entityId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
}

model UserMenuAccess {
  id         String  @id @default(cuid())
  userId     String
  menuKey    String  // "itemPrice", "myEntityStock", "allEntityStock", "itemAdjustment", "transfer", "receive", "salesOrder", "salesReturn", "incentive", "reports"
  visible    Boolean @default(true)
  // ★ Per-menu action permissions (Req #1: replace the global canCreateItem/canModifyItem toggles)
  // If visible=false, the user can't see the menu at all and these flags are ignored.
  canCreate  Boolean @default(false)  // Show "+New" buttons for this menu
  canEdit    Boolean @default(false)  // Show Edit buttons for this menu
  canDelete  Boolean @default(false)  // Show Delete buttons for this menu
  // ★ Per-menu data-transfer permissions (Req #2)
  canUpload  Boolean @default(false)  // Show "Upload CSV" / "Upload Stock" buttons for this menu
  canExport  Boolean @default(false)  // Show "Excel" / "Download" buttons for this menu
  // ★ v59: Per-menu approval permission — only users with this flag can approve
  //    purchases / sales returns / adjustments / etc.
  canApprove Boolean @default(false)  // Show Approve buttons for this menu

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, menuKey])
}

// Per-user access control for Master Data tab pages
// Allows admin to grant/revoke access to specific master data pages
// (Tailors, Making Info, UoM, Suppliers, Customers, Entities, Users, Item Information, New Item, Upload CSV)
model UserMasterDataAccess {
  id            String @id @default(cuid())
  userId        String
  masterDataKey String  // e.g. "items", "newItem", "upload", "entities", "users", "tailors", "makingInfo", "uom", "suppliers", "customers"
  visible       Boolean @default(true)
  // ★ Per-master-data action permissions (same scheme as menus)
  canCreate     Boolean @default(false)
  canEdit       Boolean @default(false)
  canDelete     Boolean @default(false)
  canUpload     Boolean @default(false)
  canExport     Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, masterDataKey])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Entity {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  // ★ Entity type: "outlet" (shop/branch), "factory", "warehouse", "head_office"
  // Used by incentive formula to determine which commission rate applies:
  //   - outlet → use outletCommission
  //   - factory → use headOfficeCommission (falls under "Head Office and others")
  //   - head_office → use headOfficeCommission
  //   - warehouse → use headOfficeCommission (falls under "Head Office and others")
  entityType  String   @default("outlet")
  // ★ Short code for the entity (e.g. "DS" for Dynasty Sylhet, "AS" for AS Display Centre)
  //    Used in Excel uploads and quick identification.
  shortCode   String?
  // ★ Company logo — base64 data URL stored in DB (no file upload needed)
  logo        String?
  // ★ v60-fix103: Address field — shows on invoices, booking prints, etc.
  address     String?
  // ★ v60-fix103: Contact phone field — shows on invoices alongside address.
  phone       String?
  // ★ v60-fix105: Parent entity (mother company). NULL = this is a top-level entity.
  //   Used to group sub-companies/branches under a mother company.
  parentEntityId String?
  parentEntity   Entity?  @relation("EntityHierarchy", fields: [parentEntityId], references: [id], onDelete: SetNull)
  childEntities  Entity[] @relation("EntityHierarchy")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAccess      UserEntityAccess[]
  stocks          Stock[]
  itemBarcodes    ItemBarcode[]
  adjustments     ItemAdjustment[]
  transfersFrom   Transfer[]         @relation("TransfersFrom")
  transfersTo     Transfer[]         @relation("TransfersTo")
  receives        Receive[]          @relation("ReceivesTo")
  receivesFrom    Receive[]          @relation("ReceivesFrom")
  salesOrders     SalesOrder[]
  salesReturns    SalesReturn[]
  incentives      Incentive[]
  bookings        Booking[]
  bookingFromItems BookingItem[] @relation("BookingFromEntity")
  salesOrderItems SalesOrderItem[] @relation("SalesOrderEntity")
  purchases       Purchase[]
  customersCreatedBy Customer[] @relation("CustomerCreatedByEntity")
  supplierPayments SupplierPayment[]
  tailorPayments   TailorPayment[]
  deliveries       Delivery[]
  accountsEntries  AccountsEntry[]
  sentMessages     ChatMessage[]   @relation("ChatFromEntity")
  receivedMessages ChatMessage[]   @relation("ChatToEntity")
}

// ★ Chat message — entity to entity messaging
model ChatMessage {
  id           String   @id @default(cuid())
  fromEntityId String
  toEntityId   String
  message      String
  createdBy    String?
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  fromEntity Entity @relation("ChatFromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity   Entity @relation("ChatToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([createdAt])
}

// ★ News Ticker — admin/manager broadcast messages shown as scrolling text
model NewsTicker {
  id        String   @id @default(cuid())
  message   String
  status    String   @default("active") // "active" or "inactive"
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ★ v60: Manual accounts entries — income, expense, and daily sales summary
// Each entity can record their own daily sales (by payment type) and other income/expenses.
// Entity sees only their own entries. Head Office (admin/manager) sees all.
model AccountsEntry {
  id             String   @id @default(cuid())
  entityId       String
  entryDate      DateTime @default(now())
  entryType      String   // "income", "expense", "sales"
  category       String   // For income/expense: "rent", "salary", "utilities", "misc", etc. For sales: "daily_sales"
  // ★ For sales entries: amount per payment type
  cashAmount     Float    @default(0)
  cardAmount     Float    @default(0)
  chequeAmount   Float    @default(0)
  mobileAmount   Float    @default(0)
  // ★ For income/expense entries: single amount
  amount         Float    @default(0)
  paymentType    String?  // For income/expense: "cash", "card", "cheque", "mobile_banking", "bank"
  description    String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([entryDate])
  @@index([entryType])
  @@index([entityId, entryDate])
}

// ★ v60: Master data for Income/Expense categories — admin can add/edit/delete
model AccountsCategory {
  id          String   @id @default(cuid())
  name        String
  entryType   String   // "income" or "expense"
  description String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, entryType])
  @@index([entryType])
}

model Item {
  id          String   @id @default(cuid())
  year        String
  lcNo        String
  group       String
  subGroup    String
  itemName    String
  price       Float
  uom         String   @default("PCS")
  barcode     String?  @unique
  itemCode    String?
  // ★ Optional descriptive fields (non-mandatory)
  color       String?
  pattern     String?
  supplierCode String?
  dimension   String?
  description String?
  supplierId  String?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stocks         Stock[]
  barcodes       ItemBarcode[]
  supplier       Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  adjustments    ItemAdjustment[]
  transfers    Transfer[]
  receives     Receive[]
  salesOrderItems SalesOrderItem[]
  salesReturns SalesReturn[]
  bookingItems BookingItem[]
  incentives   Incentive[]
  incentiveFormulaItems IncentiveFormulaItem[]
  purchaseItems PurchaseItem[]

  @@index([itemName])
  @@index([itemCode])
  @@index([barcode])
  @@index([year])
  @@index([lcNo])
  @@index([group])
  @@index([subGroup])
  @@index([createdAt])
  @@unique([itemName])
}

model Stock {
  id       String @id @default(cuid())
  itemId   String
  entityId String
  quantity Float  @default(0)

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([itemId, entityId])
  @@index([entityId])
  @@index([entityId, itemId])
}

// ★ ItemBarcode — one item can have MULTIPLE barcodes, each with its own stock qty per entity.
// This allows: Item "AN-2005-22X22X4" has barcode "BC-001" (qty 7) + barcode "BC-002" (qty 6)
// Delivery scans exact barcode → decrements from that specific barcode's stock
model ItemBarcode {
  id        String @id @default(cuid())
  itemId    String
  barcode   String
  entityId  String
  quantity  Float  @default(0)

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([barcode, entityId])
  @@index([itemId, entityId])
  @@index([barcode])
}

// ---- Master Data Models (Head Office) ----

model Group {
  id          String      @id @default(cuid())
  name        String      @unique
  description String      @default("")
  status      String      @default("active")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  subGroups   SubGroup[]
}

model SubGroup {
  id          String   @id @default(cuid())
  name        String
  groupId     String
  description String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([name, groupId])
}

model Tailor {
  id             String   @id @default(cuid())
  name           String
  phone          String   @default("")
  address        String   @default("")
  specialization String   @default("")  // e.g. "Shirt", "Pant", "Suit"
  status         String   @default("active") // "active" or "inactive"
  // ★ Comma-separated list of entity IDs this tailor is assigned to.
  // Empty string = available to all entities (back-compat).
  // When creating a sales order making entry, only tailors assigned to the
  // current working entity (or with empty entityIds) appear in the dropdown.
  entityIds      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  incentives Incentive[]
  payments   TailorPayment[]

  @@index([status])
}

// ★ Tailor Payment — tracks payments made to tailors for their work on sales orders.
// Linked to a specific SalesOrder so we know which sale's tailor is being paid.
// Supports PARTIAL payments: a tailor may receive multiple payments over time
// for the same sales order (e.g. advance + final settlement).
// The total payable for a sales order = sum of SalesMakingEntry (unitPrice × quantity).
// The total paid = sum of TailorPayment.amount for that sales order + tailor.
model TailorPayment {
  id           String   @id @default(cuid())
  salesOrderId String
  tailorId     String
  entityId     String
  amount       Float   // amount paid in this transaction (partial allowed)
  paymentDate  DateTime @default(now())
  paymentType  String   @default("cash") // cash, mobile_banking, bank, cheque
  referenceNo  String?  // e.g. mobile banking tx id, cheque no
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  tailor     Tailor     @relation(fields: [tailorId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
  @@index([tailorId])
  @@index([entityId])
  @@index([paymentDate])
}

// ★ Delivery — each partial/full delivery for a sales order gets its own record + challan.
// A sales order can have multiple deliveries over time (e.g. some items today, more tomorrow).
// Each delivery decrements stock at creation time (atomic with stock guard).
// A delivery, once created, cannot be modified by regular users (admin can reverse).
model Delivery {
  id             String   @id @default(cuid())
  deliveryNo     String   @unique  // DL-YYYYMMDD-XXXX
  salesOrderId   String
  entityId       String
  deliveryDate   DateTime @default(now())
  deliveryPerson String?
  deliveryNotes  String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salesOrder SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  entity     Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)
  items      DeliveryItem[]

  @@index([salesOrderId])
  @@index([entityId])
  @@index([deliveryDate])
  @@index([entityId, deliveryDate])
}

// Each line item in a delivery — links back to the sales order item it fulfills.
model DeliveryItem {
  id               String  @id @default(cuid())
  deliveryId       String
  salesOrderItemId String
  itemId           String
  quantity         Float
  uom              String?

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([salesOrderItemId])
  @@index([itemId])
}

model MakingInfo {
  id          String   @id @default(cuid())
  name        String   // e.g. "Stitching", "Cutting", "Finishing", "Ironing"
  description String   @default("")
  cost        Float    @default(0)
  unit        String   @default("PCS")
  status      String   @default("active") // "active" or "inactive"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UoM {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "PCS", "KG", "LTR", "MTR", "BOX", "SET", "DOZ", "PACK"
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  email     String   @default("")
  address   String   @default("")
  status    String   @default("active") // "active" or "inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items Item[]
  purchases Purchase[]
  payments SupplierPayment[]
}

// ★ Supplier Payment — track payments made to suppliers
model SupplierPayment {
  id          String   @id @default(cuid())
  supplierId  String
  purchaseId  String?  // optional link to a specific purchase
  entityId    String   // which entity made the payment
  amount      Float
  paymentDate DateTime @default(now())
  paymentType String   @default("cash") // cash, card, mobile_banking, cheque
  chequeNo    String?
  bankName    String?
  notes       String?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  entity   Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([entityId])
  @@index([purchaseId])
}

// ★ Employee master data — used to track staff and their functional roles
// (sales person, accounts, inventory). Linked from SalesOrder.salesPersonId.
model Employee {
  id          String   @id @default(cuid())
  name        String
  phone       String   @default("")
  email       String   @default("")
  address     String   @default("")
  designation String   @default("")  // e.g. "Sales Executive", "Accountant"
  // Role tags — a single employee can hold multiple roles (stored as comma-separated)
  // e.g. "sales,accounts" or "inventory" or "sales,inventory,accounts"
  roles       String   @default("")  // comma-separated: "sales", "accounts", "inventory"
  status      String   @default("active")  // "active" or "inactive"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesOrders SalesOrder[]  // sales orders where this employee was the sales person

  @@index([roles])
  @@index([status])
}

// ★ Purchase module — for tracking inventory purchases from suppliers
// Flow:
//   1. User creates a Purchase (status="pending") with multiple items
//   2. Admin/Manager approves the Purchase (status="approved")
//      → automatically creates Receive entries for each item (entityId = purchase.entityId)
//      → each Receive increments stock for that entity
//   3. After approval, user can print barcodes for all received items using purchase ID
model Purchase {
  id           String   @id @default(cuid())
  purchaseNo   String   @unique  // PUR-YYYYMMDD-XXXX
  purchaseDate DateTime @default(now())
  purchaseType String   @default("local")  // "foreign" or "local"
  entityId     String   // "Purchase For" — which entity is receiving the items
  supplierId   String?
  billNo       String?
  // ★ v59: Foreign purchase additional fields
  lcNo         String?  // LC Number (foreign only)
  piNo         String?  // P.I. Number (foreign only)
  bankName     String?  // Bank Name (foreign only)
  // ★ v59: Shipping To (for both local and foreign)
  shippingTo   String?  // Shipping destination address/entity
  status       String   @default("pending")  // "pending", "approved", "cancelled"
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  entity   Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    PurchaseItem[]
  receives Receive[]
  supplierPayments SupplierPayment[]

  @@index([entityId])
  @@index([supplierId])
  @@index([status])
  @@index([purchaseType])
  @@index([entityId, status])
}

// ★ One Purchase can have multiple items
model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  itemId      String
  quantity    Int
  unitPrice   Float
  uom         String  @default("PCS")
  total       Float   // quantity * unitPrice (denormalized for fast reporting)
  // ★ COGS (Cost of Goods Sold) — additional per-unit costs like transport, customs, etc.
  // Default 0. Total COGS for this line = cogsPerUnit * quantity.
  cogsPerUnit Float   @default(0)
  cogsNotes   String?  // optional note explaining the COGS (e.g. "Transport from Chittagong")
  // Landed cost per unit = unitPrice + cogsPerUnit (denormalized for reporting)
  landedCostPerUnit Float @default(0)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([itemId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @default("")
  email     String   @default("")
  address   String   @default("")
  type      String   @default("regular") // "regular", "wholesale", "corporate"
  status    String   @default("active") // "active" or "inactive"
  // ★ Customer is now GLOBAL — accessible from any entity.
  // createdByEntityId tracks which entity first created this customer (for audit only).
  createdByEntityId String?
  createdBy         String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByEntity Entity? @relation("CustomerCreatedByEntity", fields: [createdByEntityId], references: [id], onDelete: SetNull)
  salesOrders  SalesOrder[]
  salesReturns SalesReturn[]
  bookings     Booking[]

  @@index([createdByEntityId])
}

// ---- Transaction Models (Entity-level) ----

model ItemAdjustment {
  id             String   @id @default(cuid())
  itemId         String
  entityId       String
  adjustmentType String   // "increase" or "decrease"
  quantity       Int
  reason         String
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([itemId])
  @@index([createdAt])
}

model Transfer {
  id           String   @id @default(cuid())
  itemId       String
  barcode      String?  // ★ specific barcode being transferred (for multi-barcode items)
  fromEntityId String
  toEntityId   String
  quantity     Float    @default(0) // ★ v60-fix120: changed from Int to Float to support decimal quantities (e.g. Adhesive 0.250 Ltr)
  status       String   @default("pending") // "pending", "approved", "completed", "cancelled"
  batchId      String?  // ★ groups multiple transfers created in one multi-transfer action
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  item       Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromEntity Entity @relation("TransfersFrom", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntity   Entity @relation("TransfersTo", fields: [toEntityId], references: [id], onDelete: Cascade)

  @@index([fromEntityId])
  @@index([toEntityId])
  @@index([createdAt])
  @@index([fromEntityId, status])
  @@index([toEntityId, status])
  @@index([barcode])
  @@index([batchId])
}

model Receive {
  id             String   @id @default(cuid())
  itemId         String
  barcode        String?  // ★ specific barcode being received (for multi-barcode items)
  entityId       String
  quantity       Int
  sourceEntityId String?  // if received from another entity (transfer)
  purchaseId     String?  // ★ if received from a purchase (after approval)
  referenceNo    String?
  notes          String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  item         Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity       Entity  @relation("ReceivesTo", fields: [entityId], references: [id], onDelete: Cascade)
  sourceEntity Entity? @relation("ReceivesFrom", fields: [sourceEntityId], references: [id], onDelete: SetNull)
  purchase     Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@index([barcode])
}

model SalesOrder {
  id            String         @id @default(cuid())
  salesNo       String         @unique
  entityId      String
  customerId    String
  salesPersonId String?  // ★ optional link to Employee who made the sale
  orderDate     DateTime       @default(now())
  deliveryDate  DateTime?
  status        String         @default("pending")
  discount      Float          @default(0) // ★ flat discount amount
  // ★ v60-fix110: Simple flag — does this order have a broker?
  //   If true, the order shows up in the Broker Commission menu's summary list,
  //   where the user can click the sales ID to open the broker details form.
  //   If false, it doesn't appear in the Broker menu at all.
  hasBroker     Boolean        @default(false)
  // ★ Delivery management fields
  deliveryPerson  String?  // name of delivery person
  deliveryStatus  String   @default("pending") // pending, out_for_delivery, delivered, failed
  deliveryNotes   String?
  notes         String?
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  entity      Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesPerson Employee?       @relation(fields: [salesPersonId], references: [id], onDelete: SetNull)
  items       SalesOrderItem[]
  payments   SalesPayment[]
  returns    SalesReturn[]
  tailorPayments TailorPayment[]
  deliveries    Delivery[]

  @@index([entityId])
  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@index([createdAt])
  @@index([entityId, status, createdAt])
  @@index([entityId, createdAt])
}

// Multiple items per sales order with unit price
model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  itemId       String
  entityId     String
  quantity     Float   @default(1)
  unitPrice    Float   @default(0)

  makingEntries SalesMakingEntry[]

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity     Entity     @relation("SalesOrderEntity", fields: [entityId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
}

// Multiple making entries per sales item with making unit price
model SalesMakingEntry {
  id              String  @id @default(cuid())
  salesOrderItemId String
  makingInfoId    String?
  name            String  // making process name
  unitPrice       Float   @default(0)
  quantity        Float   @default(1)

  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)

  @@index([salesOrderItemId])
}

// Multiple payments per sales order
model SalesPayment {
  id           String   @id @default(cuid())
  salesOrderId String
  receiptNo    String   @unique
  amount       Float
  paymentType  String   // "cash", "card", "mobile_banking", "cheque"
  paymentMode  String   // "advance" or "collection"
  paymentDate  DateTime @default(now())
  chequeNo     String?
  bankName     String?
  notes        String?
  createdBy    String?
  createdAt    DateTime @default(now())

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([salesOrderId])
}

model SalesReturn {
  id           String   @id @default(cuid())
  itemId       String
  entityId     String
  customerId   String
  salesOrderId String?
  quantity     Int
  price        Float
  reason       String
  status       String   @default("pending") // "pending", "approved", "rejected"
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  item       Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity     Entity      @relation(fields: [entityId], references: [id], onDelete: Cascade)
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
}

model BookingReason {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Incentive {
  id        String   @id @default(cuid())
  itemId    String
  entityId  String
  tailorId  String?
  amount    Float
  type      String   // "tailor", "sales", "bonus", "formula"
  status    String   @default("pending") // "pending", "paid", "cancelled"
  notes     String?
  // ★ Link to the formula that generated this incentive (if auto-generated)
  formulaId String?
  // ★ Link to the sales order item that triggered this incentive (if auto-generated)
  salesOrderItemId String?
  // ★ Number of units the commission was calculated for
  units     Int      @default(1)
  // ★ Sale price per unit at the time of sale (for audit)
  saleUnitPrice Float?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item    Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entity  Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  tailor  Tailor? @relation(fields: [tailorId], references: [id], onDelete: SetNull)
  formula IncentiveFormula? @relation(fields: [formulaId], references: [id], onDelete: SetNull)
}

// ★ Incentive Formula — defines commission rules for items based on sale price ranges
// A single formula can have MULTIPLE ranges (e.g. 700-1000, 1001-1500, 1501-2000)
// Each range has two commission rates:
//   - outletCommission: applies to all entities of type "outlet"
//   - headOfficeCommission: applies to entities of type "head_office", "factory" and "warehouse" (Head Office and others)
// A single formula can include multiple items (via IncentiveFormulaItem).
model IncentiveFormula {
  id              String   @id @default(cuid())
  name            String   // e.g. "Fresh Fabric", "Premium Bed Sheet"
  description     String?
  status          String   @default("active") // "active" or "inactive"
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ranges  IncentiveFormulaRange[]
  items   IncentiveFormulaItem[]
  incentives Incentive[]  // incentives auto-generated from this formula

  @@index([status])
}

// ★ Each range within a formula has its own price window and commission rates
model IncentiveFormulaRange {
  id                  String  @id @default(cuid())
  formulaId           String
  priceFrom           Float   // inclusive
  priceTo             Float   // inclusive
  outletCommission    Float   @default(0) // per unit, for entities of type "outlet"
  headOfficeCommission Float  @default(0) // per unit, for "head_office" and "warehouse" and others
  createdAt           DateTime @default(now())

  formula IncentiveFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  @@index([formulaId])
}

// ★ Link table: which items are covered by which formula
model IncentiveFormulaItem {
  id          String @id @default(cuid())
  formulaId   String
  itemId      String
  createdAt   DateTime @default(now())

  formula IncentiveFormula @relation(fields: [formulaId], references: [id], onDelete: Cascade)
  item    Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([formulaId, itemId])
  @@index([formulaId])
  @@index([itemId])
}

model Booking {
  id           String        @id @default(cuid())
  bookingNo    String        @unique
  entityId     String        // "For Entity" — who is making the booking
  customerId   String?
  bookingDate  DateTime      @default(now())
  tillDate     DateTime?
  status       String        @default("pending")
  reason       String?
  notes        String?
  createdBy    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  entity   Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    BookingItem[]

  @@index([entityId])
  @@index([status])
  @@index([bookingDate])
  @@index([status, bookingDate])
}

// Each booking can have multiple items, each with its own "From Entity"
model BookingItem {
  id          String  @id @default(cuid())
  bookingId   String
  itemId      String
  fromEntityId String  // "From Entity" — which entity the item is booked from
  quantity    Int     @default(1)

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  item        Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromEntity  Entity  @relation("BookingFromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([fromEntityId])
  @@index([fromEntityId, itemId])
}

// ★ Broker Commission — tracks commission paid to brokers for sales orders.
// Created manually OR auto-created when Sales Order has 'brokerCommission' = true.
model BrokerCommission {
  id                String   @id @default(cuid())
  brokerName        String
  brokerContact     String?
  brokerAddress     String?
  salesOrderId      String?
  orderDate         DateTime @default(now())
  salesPersonName   String?
  commissionAmount  Float    @default(0)
  commissionType    String   @default("amount") // "amount" or "percentage"
  commissionRate    Float?   // if percentage, the rate (e.g. 5 for 5%)
  paymentType       String   @default("cash") // "cash", "mobile_banking", "cheque", "bank_deposit"
  paymentDetails    String?  // mobile banking ref, cheque no, bank deposit ref etc
  paidStatus        String   @default("unpaid") // "unpaid", "paid"
  deliveryStatus    String   @default("pending") // "pending", "delivered"
  checkedBy         String?
  approvedBy        String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([brokerName])
  @@index([salesOrderId])
  @@index([orderDate])
  @@index([paidStatus])
}
